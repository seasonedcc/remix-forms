{
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "compilerOptions": {
    "target": "es2019",
    "jsx": "react-jsx",
    "module": "preserve",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./tsc/",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
