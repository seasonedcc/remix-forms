{
  "name": "remix-forms",
  "version": "5.0.0-alpha.7",
  "description": "The full-stack form library for React Router v7",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": ["README.md", "./dist/*"],
  "license": "MIT",
  "scripts": {
    "build": "rm -rf dist && tsup ./src/index.ts --format esm,cjs --dts --external react",
    "dev": "tsup ./src/index.ts --format esm,cjs --watch --dts --external react",
    "tsc": "tsc",
    "test": "vitest run"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seasonedcc/remix-forms.git"
  },
  "bugs": {
    "url": "https://github.com/seasonedcc/remix-forms/issues"
  },
  "homepage": "https://remix-forms.seasoned.cc",
  "keywords": [
    "remix",
    "forms",
    "actions",
    "standard-schema",
    "typescript",
    "react-hook-form"
  ],
  "author": "Daniel Weinmann",
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@standard-schema/spec": "^1.0.0"
  },
  "peerDependencies": {
    "coerce-form-data": ">=2",
    "schema-info": ">=0.3.0",
    "composable-functions": ">=5",
    "react": ">=18",
    "react-hook-form": ">=7.27",
    "react-router": ">=7"
  },
  "devDependencies": {
    "coerce-form-data": "2.0.0",
    "schema-info": "0.3.0",
    "arktype": "^2.2.0",
    "effect": "^3.20.0",
    "joi": "^18.0.2",
    "valibot": "^1.3.1",
    "yup": "^1.7.1",
    "zod": "^4.0.0",
    "@types/react": ">=18",
    "@types/react-dom": ">=18",
    "react": ">=18",
    "react-dom": ">=18",
    "react-router": "7.13.1",
    "tsup": "^8.3.5",
    "typescript": "5.8.3",
    "vite": "6.0.7",
    "vitest": "2.1.8"
  }
}
